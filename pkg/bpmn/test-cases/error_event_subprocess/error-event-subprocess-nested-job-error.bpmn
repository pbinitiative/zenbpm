<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zenbpm="http://zenbpm.pbinitiative.org/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_error_event_subprocess_nested_job_error" targetNamespace="http://bpmn.io/schema/bpmn" exporter="ZenBPM Modeler" exporterVersion="1.0.0">
  <bpmn:process id="error-event-subprocess-nested-job-error" name="Nested Job Error Propagated To Parent Error Event Subprocess" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_main</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_main" sourceRef="StartEvent_1" targetRef="embedded-sub" />
    <bpmn:subProcess id="embedded-sub" name="Embedded subprocess">
      <bpmn:incoming>Flow_start_main</bpmn:incoming>
      <bpmn:outgoing>Flow_sub_success</bpmn:outgoing>
      <bpmn:startEvent id="embedded-start">
        <bpmn:outgoing>Flow_embedded_start</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_embedded_start" sourceRef="embedded-start" targetRef="nested-service-task" />
      <bpmn:serviceTask id="nested-service-task" name="Nested task">
        <bpmn:extensionElements>
          <zenbpm:taskDefinition type="error-event-subprocess-nested-job-error-task" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_embedded_start</bpmn:incoming>
        <bpmn:outgoing>Flow_embedded_end</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_embedded_end" sourceRef="nested-service-task" targetRef="embedded-end" />
      <bpmn:endEvent id="embedded-end" name="Embedded end">
        <bpmn:incoming>Flow_embedded_end</bpmn:incoming>
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_sub_success" sourceRef="embedded-sub" targetRef="should-not-happen-end" />
    <bpmn:endEvent id="should-not-happen-end" name="Should not happen end">
      <bpmn:incoming>Flow_sub_success</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="error-event-subprocess" triggeredByEvent="true">
      <bpmn:extensionElements>
        <zenbpm:ioMapping>
          <zenbpm:output source="=&#34;nested-job-error-caught&#34;" target="subProcessResult" />
        </zenbpm:ioMapping>
      </bpmn:extensionElements>
      <bpmn:startEvent id="error-start-event">
        <bpmn:outgoing>Flow_error_sub</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_sub" errorRef="Error_fail_test" />
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_error_sub" sourceRef="error-start-event" targetRef="handled-end" />
      <bpmn:endEvent id="handled-end" name="Handled end">
        <bpmn:incoming>Flow_error_sub</bpmn:incoming>
      </bpmn:endEvent>
    </bpmn:subProcess>
  </bpmn:process>
  <bpmn:error id="Error_fail_test" name="Fail test error" errorCode="42" />
