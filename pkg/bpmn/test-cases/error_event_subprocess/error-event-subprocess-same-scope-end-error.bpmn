  <bpmn:process id="error-event-subprocess-same-scope-end-error" name="Error End Event Caught By Same Scope Error Event Subprocess" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_throw</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_throw" sourceRef="StartEvent_1" targetRef="throwing-error-end" />
    <bpmn:endEvent id="throwing-error-end" name="Throw error">
      <bpmn:incoming>Flow_start_throw</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_throw" errorRef="Error_fail_test" />
    </bpmn:endEvent>
    <bpmn:subProcess id="error-event-subprocess" triggeredByEvent="true">
      <bpmn:extensionElements>
        <zenbpm:ioMapping>
          <zenbpm:output source="=&#34;same-scope-end-error-caught&#34;" target="subProcessResult" />
