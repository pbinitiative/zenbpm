<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_Process_eb8c7b12" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.0.0">
  <bpmn:collaboration id="LikvidaceDodavatelskeFaktury_ProcessDefinition">
    <bpmn:participant id="Participant_1tcns0a" name="4BPM Platform" processRef="LikvidaceDodavatelskeFaktury" />
    <bpmn:participant id="Participant_061xepn" name="Dodavatel" />
    <bpmn:messageFlow id="Flow_142foe9" sourceRef="SendTask_OznameniZamitnutiFaktury" targetRef="Participant_061xepn" />
    <bpmn:messageFlow id="Flow_1hvnlj0" sourceRef="SendTask_OznameniSchvaleniFaktury" targetRef="Participant_061xepn" />
  </bpmn:collaboration>
  <bpmn:process id="LikvidaceDodavatelskeFaktury" name="Likvidace dodavatelské faktury" isExecutable="true">
    <bpmn:laneSet id="LaneSet_0isovf0">
      <bpmn:lane id="Lane_1dwo18p" name="Schvalovatel dodavatelské faktury">
        <bpmn:flowNodeRef>BusinessRuleTask_StanoveniSchvalovatelu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_SchvaleniFaktury</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_0fj90gh" name="Fakturantka">
        <bpmn:flowNodeRef>ServiceTask_VytezeniFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ManualniKorekcePoVytezeni</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_KontrolaFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BusinessRuleTask_StanoveniDalsihoPostupu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CoDal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BusinessRuleTask_StanoveniObsahuOznameni</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_OznameniZamitnutiFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_OznameniSchvaleniFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_KonfiguraceUctovaniFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_ZauctovaniDodavatelskeFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FormaUhrady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_VytvoreniNavrhuPrikazuPlatby</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ZapocetFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DodavatelskaFakturaZlikvidovanaZapoctem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FakturaZamitnuta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ManualniNahraniFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_DodavatelskaFakturaProLikvidaci</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ManualniOvereniFaktury</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1rk8z7u</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DodavatelskaFakturaZlikvidovanaAProplacena</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_16m8kpr</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:serviceTask id="ServiceTask_VytezeniFaktury" name="(1) Vytěžení dat z PDF faktury">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="JobTypeVytezeniFaktury" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07p4il3</bpmn:incoming>
      <bpmn:outgoing>Flow_1xaxwoq</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_ManualniKorekcePoVytezeni" name="(2) Manuální korekce po vytěžení">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;manual-check-form&#34;" target="4BPM_FORM_KEY" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1xaxwoq</bpmn:incoming>
      <bpmn:outgoing>Flow_0f8o3sl</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="CallActivity_KontrolaFaktury" name="(3) Kontrola faktury">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="KontrolaDodavatelskeFaktury" propagateAllChildVariables="true" />
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceOrderReference" target="invoiceOrderReference" />
          <zeebe:output source="=orderExists" target="orderExists" />
          <zeebe:output source="=supplierDataMatches" target="supplierDataMatches" />
          <zeebe:output source="=isReliableVatPayer" target="isReliableVatPayer" />
          <zeebe:output source="=isBankAccountRegistered" target="isBankAccountRegistered" />
          <zeebe:output source="=hasAmountMatch" target="hasAmountMatch" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0f8o3sl</bpmn:incoming>
      <bpmn:outgoing>Flow_031zwou</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:businessRuleTask id="BusinessRuleTask_StanoveniDalsihoPostupu" name="(4) Stanovení dalšího postupu">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_StanoveniDalsihoPostupu_DodavatelskaFaktura" resultVariable="whatNextResult" />
        <zeebe:ioMapping>
          <zeebe:input source="=orderExists" target="orderExists" />
          <zeebe:input source="=supplierDataMatches" target="supplierDataMatches" />
          <zeebe:input source="=isReliableVatPayer" target="isReliableVatPayer" />
          <zeebe:input source="=isBankAccountRegistered" target="isBankAccountRegistered" />
          <zeebe:input source="=hasAmountMatch" target="hasAmountMatch" />
          <zeebe:output source="=whatNextResult" target="whatNextResult" />
          <zeebe:output source="=whatNextResult.invoiceRejectionReasonCode" target="invoiceRejectionReasonCode" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_031zwou</bpmn:incoming>
      <bpmn:outgoing>Flow_0reidu6</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_CoDal" name="Co dál?" default="Flow_PokracovatVeZpracovani">
      <bpmn:incoming>Flow_0reidu6</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualneOverit</bpmn:outgoing>
      <bpmn:outgoing>Flow_PokracovatVeZpracovani</bpmn:outgoing>
      <bpmn:outgoing>Flow_Zamitnout</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="BusinessRuleTask_StanoveniObsahuOznameni" name="(5) Stanovení obsahu oznámení">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_StanoveniObsahuOznameni_ZamitnutiDodavatelskeFaktury" resultVariable="determiningContentOfNoticeResult" />
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceRejectionReasonCode" target="whatNextResult.invoiceRejectionReasonCode" />
          <zeebe:output source="=determiningContentOfNoticeResult.title" target="title" />
          <zeebe:output source="=determiningContentOfNoticeResult.description" target="description" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Zamitnout</bpmn:incoming>
      <bpmn:incoming>Flow_0zeten0</bpmn:incoming>
      <bpmn:incoming>Flow_0ubn2qu</bpmn:incoming>
      <bpmn:outgoing>Flow_0o45i01</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sendTask id="SendTask_OznameniZamitnutiFaktury" name="(6) Oznámení o zamítnutí faktury">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="OznameniZamitnutiFaktury" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0o45i01</bpmn:incoming>
      <bpmn:outgoing>Flow_0zpwudc</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="SendTask_OznameniSchvaleniFaktury" name="(10) Oznámení o schválení faktury">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="OznameniSchvaleniFaktury" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0in5l2o</bpmn:incoming>
      <bpmn:outgoing>Flow_0mb5wmf</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="UserTask_KonfiguraceUctovaniFaktury" name="(11) Konfigurace účtování faktur">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;konfigurace-uctovani-form&#34;" target="4BPM_FORM_KEY" />
          <zeebe:output source="=payPrevodem" target="payPrevodem" />
          <zeebe:output source="=payZapoctem" target="payZapoctem" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0mb5wmf</bpmn:incoming>
      <bpmn:outgoing>Flow_0szydg4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_ZauctovaniDodavatelskeFaktury" name="(12) Zaúčtování dod. faktury">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ZauctovaniDodavatelskeFaktury" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0szydg4</bpmn:incoming>
      <bpmn:outgoing>Flow_1nnmf96</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1ahb34y">
        <bpmn:targetRef>DataStoreReference_1bvvdoj</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_FormaUhrady" name="Forma úhrady?">
      <bpmn:incoming>Flow_1nnmf96</bpmn:incoming>
      <bpmn:outgoing>Flow_Zapoctem</bpmn:outgoing>
      <bpmn:outgoing>Flow_Prevodem</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_VytvoreniNavrhuPrikazuPlatby" name="(14) Vytvoření návrhu příkazu k platbě">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="VytvoreniNavrhuPrikazuPlatby" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Prevodem</bpmn:incoming>
      <bpmn:outgoing>Flow_1jspv1p</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0j6r07t">
        <bpmn:targetRef>DataStoreReference_03auup0</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_ZapocetFaktury" name="(13) Zápočet faktury s protější fakturou / dobropisem">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;zapocet-faktury-form&#34;" target="4BPM_FORM_KEY" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Zapoctem</bpmn:incoming>
      <bpmn:outgoing>Flow_0xqjdwq</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_DodavatelskaFakturaZlikvidovanaZapoctem" name="Dodavatelská faktura zlikvidována zápočtem">
      <bpmn:incoming>Flow_0xqjdwq</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreReference_1bvvdoj" name="iDoklad" />
    <bpmn:endEvent id="EndEvent_FakturaZamitnuta" name="Faktura zamítnuta">
      <bpmn:incoming>Flow_0zpwudc</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="UserTask_ManualniNahraniFaktury" name="(0) Manuální nahráni faktúry">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;invoice-upload-form&#34;" target="4BPM_FORM_KEY" />
          <zeebe:output source="=invoiceNumber" target="invoiceNumber" />
          <zeebe:output source="=invoiceTotalNetAmount" target="invoiceTotalNetAmount" />
          <zeebe:output source="=invoiceOrderReference" target="invoiceOrderReference" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ezu2nf</bpmn:incoming>
      <bpmn:outgoing>Flow_07p4il3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_DodavatelskaFakturaProLikvidaci" name="Dodavatelská faktura k likvidaci">
      <bpmn:outgoing>Flow_1ezu2nf</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_07p4il3" sourceRef="UserTask_ManualniNahraniFaktury" targetRef="ServiceTask_VytezeniFaktury" />
    <bpmn:sequenceFlow id="Flow_1xaxwoq" sourceRef="ServiceTask_VytezeniFaktury" targetRef="UserTask_ManualniKorekcePoVytezeni" />
    <bpmn:sequenceFlow id="Flow_0f8o3sl" sourceRef="UserTask_ManualniKorekcePoVytezeni" targetRef="CallActivity_KontrolaFaktury" />
    <bpmn:sequenceFlow id="Flow_031zwou" sourceRef="CallActivity_KontrolaFaktury" targetRef="BusinessRuleTask_StanoveniDalsihoPostupu" />
    <bpmn:sequenceFlow id="Flow_0reidu6" sourceRef="BusinessRuleTask_StanoveniDalsihoPostupu" targetRef="Gateway_CoDal" />
    <bpmn:sequenceFlow id="Flow_ManualneOverit" name="K manuálnímu ověření" sourceRef="Gateway_CoDal" targetRef="UserTask_ManualniOvereniFaktury">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=whatNextResult.whatNext = "Manualne"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PokracovatVeZpracovani" name="Pokračovat dál ve zpracování" sourceRef="Gateway_CoDal" targetRef="BusinessRuleTask_StanoveniSchvalovatelu" />
    <bpmn:sequenceFlow id="Flow_Zamitnout" name="Zamítnout" sourceRef="Gateway_CoDal" targetRef="BusinessRuleTask_StanoveniObsahuOznameni">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=whatNextResult.whatNext = "Zamitnuto"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_16po2p3" sourceRef="UserTask_ManualniOvereniFaktury" targetRef="Gateway_1rk8z7u" />
    <bpmn:sequenceFlow id="Flow_1ila9f9" sourceRef="BusinessRuleTask_StanoveniSchvalovatelu" targetRef="UserTask_SchvaleniFaktury" />
    <bpmn:sequenceFlow id="Flow_0o45i01" sourceRef="BusinessRuleTask_StanoveniObsahuOznameni" targetRef="SendTask_OznameniZamitnutiFaktury" />
    <bpmn:sequenceFlow id="Flow_0zpwudc" sourceRef="SendTask_OznameniZamitnutiFaktury" targetRef="EndEvent_FakturaZamitnuta" />
    <bpmn:sequenceFlow id="Flow_0mb5wmf" sourceRef="SendTask_OznameniSchvaleniFaktury" targetRef="UserTask_KonfiguraceUctovaniFaktury" />
    <bpmn:sequenceFlow id="Flow_0szydg4" sourceRef="UserTask_KonfiguraceUctovaniFaktury" targetRef="ServiceTask_ZauctovaniDodavatelskeFaktury" />
    <bpmn:sequenceFlow id="Flow_1nnmf96" sourceRef="ServiceTask_ZauctovaniDodavatelskeFaktury" targetRef="Gateway_FormaUhrady" />
    <bpmn:sequenceFlow id="Flow_Zapoctem" name="Zápočtem" sourceRef="Gateway_FormaUhrady" targetRef="UserTask_ZapocetFaktury">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=payZapoctem = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Prevodem" name="Převodem" sourceRef="Gateway_FormaUhrady" targetRef="ServiceTask_VytvoreniNavrhuPrikazuPlatby">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=payPrevodem = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jspv1p" sourceRef="ServiceTask_VytvoreniNavrhuPrikazuPlatby" targetRef="EndEvent_DodavatelskaFakturaZlikvidovanaAProplacena" />
    <bpmn:sequenceFlow id="Flow_0xqjdwq" sourceRef="UserTask_ZapocetFaktury" targetRef="EndEvent_DodavatelskaFakturaZlikvidovanaZapoctem" />
    <bpmn:sequenceFlow id="Flow_1ezu2nf" sourceRef="StartEvent_DodavatelskaFakturaProLikvidaci" targetRef="UserTask_ManualniNahraniFaktury" />
    <bpmn:userTask id="UserTask_ManualniOvereniFaktury" name="(7) Manuální ověření dod. faktury">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;manual-overeni-form&#34;" target="4BPM_FORM_KEY" />
          <zeebe:output source="=poslatKeSchvaleni" target="poslatKeSchvaleni" />
          <zeebe:output source="=invoiceRejectionReasonCode" target="invoiceRejectionReasonCode" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ManualneOverit</bpmn:incoming>
      <bpmn:outgoing>Flow_16po2p3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0w5754q" name="Ne" sourceRef="Gateway_1rk8z7u" targetRef="BusinessRuleTask_StanoveniSchvalovatelu">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=poslatKeSchvaleni = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_1rk8z7u" name="Faktura zamítnuta?" default="Flow_0zeten0">
      <bpmn:incoming>Flow_16po2p3</bpmn:incoming>
      <bpmn:outgoing>Flow_0w5754q</bpmn:outgoing>
      <bpmn:outgoing>Flow_0zeten0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="BusinessRuleTask_StanoveniSchvalovatelu" name="(8) Stanovení schvalovatelů">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_StanoveniSchvalovatelu_DodavatelskeFaktury" resultVariable="designationOfApproversResult" />
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceTotalNetAmount" target="invoiceTotalNetAmount" />
          <zeebe:output source="=designationOfApproversResult" target="designationOfApproversResult" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PokracovatVeZpracovani</bpmn:incoming>
      <bpmn:incoming>Flow_0w5754q</bpmn:incoming>
      <bpmn:outgoing>Flow_1ila9f9</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="UserTask_SchvaleniFaktury" name="(9) Schválení faktury">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;invoice-approval-form&#34;" target="4BPM_FORM_KEY" />
          <zeebe:output source="=schvaleno" target="schvaleno" />
          <zeebe:output source="=invoiceRejectionReasonCode" target="invoiceRejectionReasonCode" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ila9f9</bpmn:incoming>
      <bpmn:outgoing>Flow_0kv908p</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0zeten0" name="Ano" sourceRef="Gateway_1rk8z7u" targetRef="BusinessRuleTask_StanoveniObsahuOznameni" />
    <bpmn:sequenceFlow id="Flow_0kv908p" sourceRef="UserTask_SchvaleniFaktury" targetRef="Gateway_16m8kpr" />
    <bpmn:sequenceFlow id="Flow_0ubn2qu" name="Ano" sourceRef="Gateway_16m8kpr" targetRef="BusinessRuleTask_StanoveniObsahuOznameni" />
    <bpmn:sequenceFlow id="Flow_0in5l2o" name="Ne" sourceRef="Gateway_16m8kpr" targetRef="SendTask_OznameniSchvaleniFaktury">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=schvaleno = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="EndEvent_DodavatelskaFakturaZlikvidovanaAProplacena" name="Dodavatelská faktura zlikvidována a proplacena">
      <bpmn:incoming>Flow_1jspv1p</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStoreReference_03auup0" name="Evidence návrhů příkazů k platbě" />
    <bpmn:exclusiveGateway id="Gateway_16m8kpr" name="Zamítnuto?" default="Flow_0ubn2qu">
      <bpmn:incoming>Flow_0kv908p</bpmn:incoming>
      <bpmn:outgoing>Flow_0ubn2qu</bpmn:outgoing>
      <bpmn:outgoing>Flow_0in5l2o</bpmn:outgoing>
    </bpmn:exclusiveGateway>
  </bpmn:process>
  <bpmn:message id="Message_2f1eoiv" name="Message Stanoveni obsahu oznameni">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=invoiceNumber" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_3ofhjk6" name="Vráceno k opravě">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=invoiceNumber" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_0oovh8n" name="Message Zamítnuto">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=invoiceNumber" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="LikvidaceDodavatelskeFaktury_ProcessDefinition">
      <bpmndi:BPMNShape id="Participant_1tcns0a_di" bpmnElement="Participant_1tcns0a" isHorizontal="true">
        <dc:Bounds x="160" y="170" width="1880" height="510" />
