  <decision id="Decision_StanoveniDalsihoPostupu_DodavatelskaFaktura" name="Stanovení dalšího postupu s dodavatelskou fakturou">
    <decisionTable id="DecisionTable_198kpsd">
      <input id="Input_1" label="Existuje objednávka?">
        <inputExpression id="InputExpression_1" typeRef="boolean">
          <text>orderExists</text>
        </inputExpression>
      </input>
      <input id="InputClause_1skdzpm" label="Údaje o dodavateli souhlasí s evidencí?">
        <inputExpression id="LiteralExpression_1d29err" typeRef="boolean">
          <text>supplierDataMatches</text>
        </inputExpression>
      </input>
      <input id="InputClause_05ekijj" label="Spolehlivý plátce DPH?">
        <inputExpression id="LiteralExpression_08ug52k" typeRef="boolean">
          <text>isReliableVatPayer</text>
        </inputExpression>
      </input>
      <input id="InputClause_0aycb2j" label="Bank.účet nalezen v registru DPH?">
        <inputExpression id="LiteralExpression_18l6zk5" typeRef="boolean">
          <text>isBankAccountRegistered</text>
        </inputExpression>
      </input>
      <input id="InputClause_1sbi7y8" label="Soulad součtů: Faktura vs. Objednávka?" biodi:width="192">
        <inputExpression id="LiteralExpression_0b32xac" typeRef="boolean">
          <text>hasAmountMatch</text>
        </inputExpression>
      </input>
      <output id="Output_1" label="Další způsob řešení" name="whatNext" typeRef="string" />
      <output id="OutputClause_05n1wzy" label="Vyplatit pouze částku bez DPH?" name="shouldPayWithoutVat" typeRef="boolean" biodi:width="192" />
      <output id="OutputClause_0cm6tit" label="Kód zamítnutí" name="invoiceRejectionReasonCode" typeRef="string" biodi:width="192" />
      <rule id="DecisionRule_1o0an20">
