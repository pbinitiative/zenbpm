<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="Definitions_Decision_hit_policy_collect_unnamed_output" name="Hit Policy Collect Unnamed Output" namespace="http://example.com/dmn">
  <decision id="dmn_hit_policy_collect_unnamed_output" name="DMN Hit Policy Collect Unnamed Output">
    <decisionTable id="hit_policy_collect_unnamed_output_table" hitPolicy="COLLECT">
      <input id="input_collect_unnamed_output_score" label="Score">
        <inputExpression id="inputExpression_collect_unnamed_output_score" typeRef="number">
          <text>score</text>
        </inputExpression>
      </input>
      <output id="output_collect_unnamed_output_discount" label="Discount" typeRef="number" />
      <rule id="rule_collect_unnamed_output_score_at_least_1">
        <inputEntry id="input_collect_unnamed_output_score_at_least_1">
          <text>&gt;= 1</text>
        </inputEntry>
        <outputEntry id="output_collect_unnamed_output_score_at_least_1">
          <text>10</text>
        </outputEntry>
      </rule>
      <rule id="rule_collect_unnamed_output_score_at_least_2">
        <inputEntry id="input_collect_unnamed_output_score_at_least_2">
          <text>&gt;= 2</text>
        </inputEntry>
        <outputEntry id="output_collect_unnamed_output_score_at_least_2">
          <text>2.5</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
