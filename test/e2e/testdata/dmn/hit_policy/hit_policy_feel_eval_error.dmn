<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="Definitions_Decision_feel_eval_error" name="FEEL Eval Error" namespace="http://example.com/dmn">
  <decision id="dmn_feel_eval_error" name="DMN FEEL Eval Error">
    <decisionTable id="feel_eval_error_table" hitPolicy="FIRST">
      <input id="input_feel_eval_error_score" label="Score">
        <inputExpression id="inputExpression_feel_eval_error_score" typeRef="number">
          <text>score</text>
        </inputExpression>
      </input>
      <output id="output_feel_eval_error_discount" label="Discount" name="discount" typeRef="number" />
      <rule id="rule_feel_eval_error_score_at_least_1">
        <inputEntry id="input_feel_eval_error_score_at_least_1">
          <text>&gt;= 1</text>
        </inputEntry>
        <outputEntry id="output_feel_eval_error_score_at_least_1">
          <text>1 +</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
