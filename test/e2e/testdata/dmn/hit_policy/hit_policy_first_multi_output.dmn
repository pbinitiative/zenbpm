<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="Definitions_Decision_hit_policy_first_multi_output" name="Hit Policy First Multi Output" namespace="http://example.com/dmn">
  <decision id="dmn_hit_policy_first_multi_output" name="DMN Hit Policy First Multi Output">
    <decisionTable id="hit_policy_first_multi_output_table" hitPolicy="FIRST">
      <input id="input_first_multi_output_score" label="Score">
        <inputExpression id="inputExpression_first_multi_output_score" typeRef="number">
          <text>score</text>
        </inputExpression>
      </input>
      <output id="output_first_multi_output_discount" label="Discount" name="discount" typeRef="number" />
      <output id="output_first_multi_output_reason" label="Reason" name="reason" typeRef="string" />
      <rule id="rule_first_multi_output_score_at_least_2">
        <inputEntry id="input_first_multi_output_score_at_least_2">
          <text>&gt;= 2</text>
        </inputEntry>
        <outputEntry id="output_first_multi_output_discount_at_least_2">
          <text>20</text>
        </outputEntry>
        <outputEntry id="output_first_multi_output_reason_at_least_2">
          <text>"high"</text>
        </outputEntry>
      </rule>
      <rule id="rule_first_multi_output_score_at_least_1">
        <inputEntry id="input_first_multi_output_score_at_least_1">
          <text>&gt;= 1</text>
        </inputEntry>
        <outputEntry id="output_first_multi_output_discount_at_least_1">
          <text>10</text>
        </outputEntry>
        <outputEntry id="output_first_multi_output_reason_at_least_1">
          <text>"base"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
