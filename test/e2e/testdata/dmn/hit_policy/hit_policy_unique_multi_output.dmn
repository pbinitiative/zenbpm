<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="Definitions_Decision_hit_policy_unique_multi_output" name="Hit Policy Unique Multi Output" namespace="http://example.com/dmn">
  <decision id="dmn_hit_policy_unique_multi_output" name="DMN Hit Policy Unique Multi Output">
    <decisionTable id="hit_policy_unique_multi_output_table" hitPolicy="UNIQUE">
      <input id="input_unique_multi_output_score" label="Score">
        <inputExpression id="inputExpression_unique_multi_output_score" typeRef="number">
          <text>score</text>
        </inputExpression>
      </input>
      <output id="output_unique_multi_output_discount" label="Discount" name="discount" typeRef="number" />
      <output id="output_unique_multi_output_reason" label="Reason" name="reason" typeRef="string" />
      <rule id="rule_unique_multi_output_score_1">
        <inputEntry id="input_unique_multi_output_score_1">
          <text>1</text>
        </inputEntry>
        <outputEntry id="output_unique_multi_output_discount_1">
          <text>10</text>
        </outputEntry>
        <outputEntry id="output_unique_multi_output_reason_1">
          <text>"base"</text>
        </outputEntry>
      </rule>
      <rule id="rule_unique_multi_output_score_2">
        <inputEntry id="input_unique_multi_output_score_2">
          <text>2</text>
        </inputEntry>
        <outputEntry id="output_unique_multi_output_discount_2">
          <text>20</text>
        </outputEntry>
        <outputEntry id="output_unique_multi_output_reason_2">
          <text>"bonus"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
