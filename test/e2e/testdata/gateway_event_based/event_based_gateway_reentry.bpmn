<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zenbpm="http://zenbpm.pbinitiative.org/1.0" id="Definitions_event_based_gateway_reentry" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="event-based-gateway-reentry" isExecutable="true">
    <bpmn:startEvent id="start_event">
      <bpmn:outgoing>Flow_start_to_gateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_to_gateway" sourceRef="start_event" targetRef="event_based_gateway" />
    <bpmn:eventBasedGateway id="event_based_gateway">
      <bpmn:incoming>Flow_start_to_gateway</bpmn:incoming>
      <bpmn:incoming>Flow_reenter_to_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_gateway_to_message_a</bpmn:outgoing>
      <bpmn:outgoing>Flow_gateway_to_message_b</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_gateway_to_message_a" sourceRef="event_based_gateway" targetRef="catch_message_loop" />
    <bpmn:sequenceFlow id="Flow_gateway_to_message_b" sourceRef="event_based_gateway" targetRef="catch_message_single" />
    <bpmn:intermediateCatchEvent id="catch_message_loop">
      <bpmn:incoming>Flow_gateway_to_message_a</bpmn:incoming>
      <bpmn:outgoing>Flow_message_a_to_task</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_gateway_a" messageRef="Message_gateway_a" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_message_single">
      <bpmn:incoming>Flow_gateway_to_message_b</bpmn:incoming>
      <bpmn:outgoing>Flow_message_b_to_task</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_gateway_b" messageRef="Message_gateway_b" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_message_a_to_task" sourceRef="catch_message_loop" targetRef="service_task_message_loop" />
    <bpmn:sequenceFlow id="Flow_message_b_to_task" sourceRef="catch_message_single" targetRef="end_event_single" />
    <bpmn:serviceTask id="service_task_message_loop">
      <bpmn:extensionElements>
        <zenbpm:taskDefinition type="event-based-message-a-task" />
        <zenbpm:ioMapping>
          <zenbpm:output source="=loopCount" target="loopCount" />
        </zenbpm:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_message_a_to_task</bpmn:incoming>
      <bpmn:outgoing>Flow_message_a_to_decision</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_message_a_to_decision" sourceRef="service_task_message_loop" targetRef="exclusive_gateway_loop_decision" />
    <bpmn:exclusiveGateway id="exclusive_gateway_loop_decision" default="Flow_reenter_to_gateway">
      <bpmn:incoming>Flow_message_a_to_decision</bpmn:incoming>
      <bpmn:outgoing>Flow_message_a_to_end</bpmn:outgoing>
      <bpmn:outgoing>Flow_reenter_to_gateway</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_message_a_to_end" sourceRef="exclusive_gateway_loop_decision" targetRef="end_event_loop">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= loopCount &gt;= 2</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_reenter_to_gateway" sourceRef="exclusive_gateway_loop_decision" targetRef="event_based_gateway" />
    <bpmn:endEvent id="end_event_loop">
      <bpmn:incoming>Flow_message_a_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_event_single">
      <bpmn:incoming>Flow_message_b_to_task</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:message id="Message_gateway_a" name="event-gateway-message-a">
    <bpmn:extensionElements>
      <zenbpm:subscription correlationKey="=correlationKey" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_gateway_b" name="event-gateway-message-b">
    <bpmn:extensionElements>
      <zenbpm:subscription correlationKey="=correlationKey" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="event-based-gateway-reentry">
      <bpmndi:BPMNShape id="start_event_di" bpmnElement="start_event">
        <dc:Bounds x="150" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="event_based_gateway_di" bpmnElement="event_based_gateway">
        <dc:Bounds x="240" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="catch_message_a_di" bpmnElement="catch_message_loop">
        <dc:Bounds x="362" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="catch_message_b_di" bpmnElement="catch_message_single">
        <dc:Bounds x="362" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_message_a_di" bpmnElement="service_task_message_loop">
        <dc:Bounds x="490" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="message_a_decision_di" bpmnElement="exclusive_gateway_loop_decision" isMarkerVisible="true">
        <dc:Bounds x="610" y="55" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_message_a_di" bpmnElement="end_event_loop">
        <dc:Bounds x="730" y="62" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_message_b_di" bpmnElement="end_event_single">
        <dc:Bounds x="617" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_gateway_di" bpmnElement="Flow_start_to_gateway">
        <di:waypoint x="186" y="200" />
        <di:waypoint x="240" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gateway_to_message_a_di" bpmnElement="Flow_gateway_to_message_a">
        <di:waypoint x="290" y="200" />
        <di:waypoint x="362" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gateway_to_message_b_di" bpmnElement="Flow_gateway_to_message_b">
        <di:waypoint x="265" y="225" />
        <di:waypoint x="265" y="350" />
        <di:waypoint x="362" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_message_a_to_task_di" bpmnElement="Flow_message_a_to_task">
        <di:waypoint x="398" y="200" />
        <di:waypoint x="490" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_message_b_to_task_di" bpmnElement="Flow_message_b_to_task">
        <di:waypoint x="398" y="350" />
        <di:waypoint x="617" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_message_a_to_decision_di" bpmnElement="Flow_message_a_to_decision">
        <di:waypoint x="590" y="200" />
        <di:waypoint x="635" y="200" />
        <di:waypoint x="635" y="105" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_message_a_to_end_di" bpmnElement="Flow_message_a_to_end">
        <di:waypoint x="660" y="80" />
        <di:waypoint x="730" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_reenter_to_gateway_di" bpmnElement="Flow_reenter_to_gateway">
        <di:waypoint x="635" y="55" />
        <di:waypoint x="635" y="10" />
        <di:waypoint x="265" y="10" />
        <di:waypoint x="265" y="175" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
