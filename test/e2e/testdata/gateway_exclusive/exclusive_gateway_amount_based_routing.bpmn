    <bpmn:sequenceFlow id="Flow_between_100_1000" name="&#62;=100 &#38; &#60; 1000" sourceRef="exclusive_gateway" targetRef="end_event_between_100_1000">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=amount &gt;=100 and amount &lt; 1000</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="end_event_between_150_200" name="Between 150 and 200">
      <bpmn:incoming>Flow_between_150_200</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_between_150_200" name="&#62;= 150 &#38; &#60; 200" sourceRef="exclusive_gateway" targetRef="end_event_between_150_200">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=amount &gt;= 150 and amount &lt; 200</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
