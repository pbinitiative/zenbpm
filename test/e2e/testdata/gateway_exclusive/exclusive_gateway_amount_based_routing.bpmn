    <bpmn:exclusiveGateway id="exclusive_gateway">
      <bpmn:incoming>Flow_035xjey</bpmn:incoming>
      <bpmn:outgoing>Flow_less_than_100</bpmn:outgoing>
      <bpmn:outgoing>Flow_between_100_1000</bpmn:outgoing>
      <bpmn:outgoing>Flow_between_150_200</bpmn:outgoing>
