    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_less_than_100" name="&#60; 100" sourceRef="exclusive_gateway" targetRef="end_event_less_than_100">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=amount &lt; 100</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="end_event_between_100_1000" name="Between 100 and 1000">
      <bpmn:incoming>Flow_between_100_1000</bpmn:incoming>
