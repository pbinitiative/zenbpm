  <bpmn:process id="inclusive_gateway_no_match_no_default" isExecutable="true">
    <bpmn:startEvent id="start_event">
      <bpmn:outgoing>Flow_start_to_gateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_start_to_gateway" sourceRef="start_event" targetRef="inclusive_gateway" />
    <bpmn:inclusiveGateway id="inclusive_gateway">
      <bpmn:incoming>Flow_start_to_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_gateway_to_end_a</bpmn:outgoing>
      <bpmn:outgoing>Flow_gateway_to_end_b</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sequenceFlow id="Flow_gateway_to_end_a" sourceRef="inclusive_gateway" targetRef="end_event_a">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=routeA</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_gateway_to_end_b" sourceRef="inclusive_gateway" targetRef="end_event_b">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=routeB</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="end_event_a">
      <bpmn:incoming>Flow_gateway_to_end_a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_event_b">
      <bpmn:incoming>Flow_gateway_to_end_b</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
