    <bpmn:sequenceFlow id="Flow_task_c_to_join" sourceRef="service_task_c" targetRef="inclusive_gateway_join" />
    <bpmn:sequenceFlow id="Flow_default_to_join" sourceRef="service_task_default" targetRef="inclusive_gateway_join" />
