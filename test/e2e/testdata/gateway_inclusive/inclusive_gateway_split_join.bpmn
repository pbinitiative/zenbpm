      <bpmn:incoming>Flow_default_to_join</bpmn:incoming>
      <bpmn:outgoing>Flow_join_to_after</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sequenceFlow id="Flow_join_to_after" sourceRef="inclusive_gateway_join" targetRef="service_task_after_join" />
    <bpmn:serviceTask id="service_task_after_join">
