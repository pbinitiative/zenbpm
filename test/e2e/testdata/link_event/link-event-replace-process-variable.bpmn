<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zenbpm="http://zenbpm.pbinitiative.org/1.0" id="Definitions_link_replace_process_variable" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="simple-link-event-replace-process-variable" name="simple-link-event-replace-process-variable" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_Start_To_Throw</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="Link-Throw" name="Link-Throw">
      <bpmn:extensionElements>
        <zenbpm:ioMapping>
          <zenbpm:output source="=&#34;throw_value&#34;" target="local_variable" />
        </zenbpm:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Throw</bpmn:incoming>
      <bpmn:linkEventDefinition id="LinkEventDefinition_Throw" name="link" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Link-Catch" name="Link-Catch">
      <bpmn:extensionElements>
        <zenbpm:ioMapping>
          <zenbpm:output source="=local_variable" target="process_variable" />
        </zenbpm:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Catch_To_Task</bpmn:outgoing>
      <bpmn:linkEventDefinition id="LinkEventDefinition_Catch" name="link" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task" name="Task">
      <bpmn:extensionElements>
        <zenbpm:taskDefinition type="task" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Catch_To_Task</bpmn:incoming>
      <bpmn:outgoing>Flow_Task_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_Task_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Throw" sourceRef="StartEvent_1" targetRef="Link-Throw" />
    <bpmn:sequenceFlow id="Flow_Catch_To_Task" sourceRef="Link-Catch" targetRef="Task" />
    <bpmn:sequenceFlow id="Flow_Task_To_End" sourceRef="Task" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="simple-link-event-replace-process-variable">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Link_Throw_di" bpmnElement="Link-Throw">
        <dc:Bounds x="288" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="280" y="125" width="55" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Link_Catch_di" bpmnElement="Link-Catch">
        <dc:Bounds x="392" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="384" y="125" width="53" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_di" bpmnElement="Task">
        <dc:Bounds x="480" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="632" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_Throw_di" bpmnElement="Flow_Start_To_Throw">
        <di:waypoint x="188" y="100" />
        <di:waypoint x="288" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Catch_To_Task_di" bpmnElement="Flow_Catch_To_Task">
        <di:waypoint x="428" y="100" />
        <di:waypoint x="480" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Task_To_End_di" bpmnElement="Flow_Task_To_End">
        <di:waypoint x="580" y="100" />
        <di:waypoint x="632" y="100" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
