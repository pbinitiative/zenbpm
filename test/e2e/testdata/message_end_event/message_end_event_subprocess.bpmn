        <di:waypoint x="650" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_followup_to_parent_end_di" bpmnElement="Flow_followup_to_parent_end">
        <di:waypoint x="750" y="190" />
        <di:waypoint x="830" y="190" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
