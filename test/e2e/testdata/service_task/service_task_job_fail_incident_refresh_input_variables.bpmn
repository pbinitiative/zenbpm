      <bpmndi:BPMNShape id="service_task_di" bpmnElement="service_task">
        <dc:Bounds x="270" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_event_di" bpmnElement="end_event">
